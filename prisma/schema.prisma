generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id         String     @id @default(cuid())
  name       String
  department Department
  githubLink String?
  liveLink   String?
  imageLinks String[]
  doubts     String?
  marks      String     @default("")
  feedback   String?
  checked    Boolean    @default(false)
  accepted   Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  userId     String
  user       User       @relation(fields: [userId], references: [id])
}

model User {
  id               String        @id @default(cuid())
  name             String
  email            String        @unique
  password         String
  role             Role          @default(MEMBER)
  domain           Department[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  resetToken       String?       @unique
  resetTokenExpiry DateTime?
  projects         Project[]
  createdQuizzes   Quiz[]        @relation("QuizCreator")
  quizAttempts     QuizAttempt[]
}

model Quiz {
  id          String        @id @default(cuid())
  title       String
  description String?
  department  Department
  status      QuizStatus    @default(DRAFT)
  timeLimit   Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   String
  questions   Question[]
  user        User          @relation("QuizCreator", fields: [createdBy], references: [id])
  attempts    QuizAttempt[]
}

model Question {
  id            String       @id @default(cuid())
  quizId        String
  type          QuestionType @default(MCQ)
  text          String
  options       String[]
  correctAnswer String?
  marks         Int          @default(1)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  quizId      String
  answers     String
  score       Float?
  feedback    String?
  status      String    @default("IN_PROGRESS")
  timeLeft    Int?
  createdAt   DateTime  @default(now())
  submittedAt DateTime?
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

enum Department {
  DSA
  WEB_DEVELOPMENT
  IOT
  GAME_DEVELOPMENT_ANIMATION
  DEVOPS_CLOUD
  ML_DATA_SCIENCE
  MEDIA_GRAPHICS_VIDEO
  CORPORATE_RELATIONS
  PHOTOGRAPHY_VIDEO_EDITING
}

enum Role {
  MEMBER
  ADMIN
}

enum QuizStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum QuestionType {
  MCQ
  DYNAMIC
}
